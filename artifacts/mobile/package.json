{
  "name": "@workspace/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --localhost --port 8082",
    "dev:offline": "set \"EXPO_OFFLINE=1\" && expo start --localhost --port 8082",
    "dev:local": "set \"EXPO_METRO_MAX_WORKERS=1\" && set \"NODE_OPTIONS=--max-old-space-size=8192\" && expo start --port 8082",
    "dev:tunnel": "set \"EXPO_METRO_MAX_WORKERS=1\" && set \"NODE_OPTIONS=--max-old-space-size=8192\" && expo start --tunnel --port 8082",
    "build": "set \"NODE_OPTIONS=--max-old-space-size=8192\" && node scripts/build.js",
    "serve": "node server/serve.js",
    "typecheck": "set \"NODE_OPTIONS=--max-old-space-size=8192\" && tsc -p tsconfig.json --noEmit",
    "test": "set \"NODE_OPTIONS=--max-old-space-size=8192\" && jest"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo/cli": "54.0.23",
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.0.1",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@ungap/structured-clone": "^1.3.0",
    "@workspace/api-client-react": "workspace:*",
    "expo": "~54.0.27",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.11",
    "expo-font": "~14.0.10",
    "expo-glass-effect": "~0.1.4",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.17",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "typescript": "~5.9.2",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.4.0"
  },
  "dependencies": {
    "@nkzw/create-context-hook": "^1.1.0",
    "@sentry/react-native": "^8.5.0",
    "@supabase/supabase-js": "^2.49.1",
    "date-fns": "^3.6.0",
    "expo-camera": "~17.0.10",
    "expo-device": "~55.0.5",
    "expo-file-system": "~19.0.21",
    "expo-image-manipulator": "~55.0.5",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~55.0.6",
    "expo-sharing": "~14.0.8",
    "i18next": "^23.16.8",
    "react-i18next": "^14.1.3",
    "react-native-maps": "1.20.1",
    "react-native-url-polyfill": "^3.0.0"
  }
